# RCI-SG Environment Configuration
# Copy this file to .env and fill in your API keys

# DeepSeek API (for malicious skill synthesis - Phase 3)
# Get key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# LLM Providers for RQ3 (cross-model validation)
# Qwen (DashScope)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: OpenClaw configuration (for realistic attack experiments)
OPENCLAW_API_URL=http://localhost:3000
OPENCLAW_API_TOKEN=your_openclaw_token
